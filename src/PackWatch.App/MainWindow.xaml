<Window
    x:Class="PackWatch.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:application="clr-namespace:PackWatch.Application.Navigation;assembly=PackWatch.Application"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PackWatch"
    Width="1180"
    Height="760"
    MinWidth="1120"
    MinHeight="720"
    mc:Ignorable="d">
    <Grid Background="{StaticResource PackWatchBackgroundBrush}">
        <Grid.Resources>
            <Style x:Key="SidebarButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="Padding" Value="10,10" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Foreground" Value="#64748B" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="NavRoot"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        x:Name="Indicator"
                                        Grid.Column="0"
                                        Width="4"
                                        Height="18"
                                        Margin="4,0,8,0"
                                        Background="{TemplateBinding BorderBrush}"
                                        CornerRadius="2" />

                                    <TextBlock
                                        x:Name="IconBlock"
                                        Grid.Column="1"
                                        Margin="4,0,12,0"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="16"
                                        Text="{TemplateBinding Tag}" />

                                    <ContentPresenter
                                        x:Name="TextContent"
                                        Grid.Column="2"
                                        Margin="0"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="NavRoot" Property="Background" Value="#F1F5F9" />
                                    <Setter Property="Foreground" Value="#0F172A" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="NavRoot" Property="Background" Value="#E2E8F0" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=CollapseToggleButton}" Value="True">
                                    <Setter TargetName="TextContent" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="IconBlock" Property="Margin" Value="4,0,0,0" />
                                    <Setter Property="ToolTip" Value="{Binding Content, RelativeSource={RelativeSource Self}}" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!--  Trigger for Home  -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding SelectedPage}" Value="{x:Static application:ApplicationPage.Home}" />
                            <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="{x:Static application:ApplicationPage.Home}" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource PackWatchAccentSoftBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource PackWatchAccentBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource PackWatchAccentDarkBrush}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </MultiDataTrigger>
                    <!--  Trigger for History  -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding SelectedPage}" Value="{x:Static application:ApplicationPage.History}" />
                            <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="{x:Static application:ApplicationPage.History}" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource PackWatchAccentSoftBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource PackWatchAccentBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource PackWatchAccentDarkBrush}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </MultiDataTrigger>
                    <!--  Trigger for Settings  -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding SelectedPage}" Value="{x:Static application:ApplicationPage.Settings}" />
                            <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="{x:Static application:ApplicationPage.Settings}" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource PackWatchAccentSoftBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource PackWatchAccentBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource PackWatchAccentDarkBrush}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>

            <!--  Brand Panel Styles  -->
            <Style x:Key="BrandExpandedStyle" TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsChecked, ElementName=CollapseToggleButton}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="BrandCollapsedStyle" TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsChecked, ElementName=CollapseToggleButton}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!--  Workspace Text Collapse  -->
            <Style x:Key="WorkspaceTextCollapseStyle" TargetType="TextBlock">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsChecked, ElementName=CollapseToggleButton}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!--  Dynamic Page Title Style  -->
            <Style
                x:Key="PageTitleTextStyle"
                BasedOn="{StaticResource PageTitleStyle}"
                TargetType="TextBlock">
                <Setter Property="Text" Value="Live Validation" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedPage}" Value="{x:Static application:ApplicationPage.History}">
                        <Setter Property="Text" Value="History" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SelectedPage}" Value="{x:Static application:ApplicationPage.Settings}">
                        <Setter Property="Text" Value="Settings" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!--  Dynamic Page Subtitle Style  -->
            <Style
                x:Key="PageSubtitleTextStyle"
                BasedOn="{StaticResource PageSubtitleStyle}"
                TargetType="TextBlock">
                <Setter Property="Text" Value="Run a local packing session, confirm the barcode manually, and save a reusable desktop artifact for review." />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedPage}" Value="{x:Static application:ApplicationPage.History}">
                        <Setter Property="Text" Value="Review the session artifacts saved from local validation runs and reopen their folders when you need to inspect evidence." />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SelectedPage}" Value="{x:Static application:ApplicationPage.Settings}">
                        <Setter Property="Text" Value="Choose one shared camera source for both live preview and recording, then tune the capture profile around that source." />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn">
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="268" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=CollapseToggleButton}" Value="True">
                                <Setter Property="Width" Value="80" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="0,0,1,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Padding" Value="20" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=CollapseToggleButton}" Value="True">
                            <Setter Property="Padding" Value="10" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <!--  Brand Header Card  -->
                    <Border
                        x:Name="BrandCard"
                        Margin="0,0,0,24"
                        Padding="12"
                        Background="{StaticResource PackWatchAccentBrush}"
                        CornerRadius="12">
                        <Grid>
                            <StackPanel Style="{StaticResource BrandExpandedStyle}">
                                <TextBlock
                                    Margin="0,0,0,2"
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="PackWatch" />
                                <TextBlock
                                    FontSize="10"
                                    Foreground="#E6F0FF"
                                    Text="Local validation console" />
                            </StackPanel>

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="White"
                                Style="{StaticResource BrandCollapsedStyle}"
                                Text="PW" />
                        </Grid>
                    </Border>

                    <TextBlock
                        Margin="2,0,0,10"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#64748B"
                        Style="{StaticResource WorkspaceTextCollapseStyle}"
                        Text="WORKSPACE" />

                    <Button
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Static application:ApplicationPage.Home}"
                        Content="Home"
                        Style="{StaticResource SidebarButtonStyle}"
                        Tag="&#xE80F;" />
                    <Button
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Static application:ApplicationPage.History}"
                        Content="History"
                        Style="{StaticResource SidebarButtonStyle}"
                        Tag="&#xE81C;" />
                    <Button
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Static application:ApplicationPage.Settings}"
                        Content="Settings"
                        Style="{StaticResource SidebarButtonStyle}"
                        Tag="&#xE713;" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  MAIN CONTENT AREA  -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header Panel containing ToggleButton close to left edge, and dynamic Title/Subtitle  -->
            <Grid Grid.Row="0" Margin="12,16,28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ToggleButton
                    x:Name="CollapseToggleButton"
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Content="&#xE700;"
                    Cursor="Hand"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="16"
                    Foreground="#64748B">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border
                                x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonRoot" Property="Background" Value="#F1F5F9" />
                                    <Setter Property="Foreground" Value="#0F172A" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <StackPanel
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Style="{StaticResource PageSubtitleTextStyle}" />
                </StackPanel>
            </Grid>

            <ContentControl
                Grid.Row="1"
                Margin="16"
                Content="{Binding CurrentPageViewModel}" />
        </Grid>
    </Grid>
</Window>
