<Window x:Class="PackWatch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:application="clr-namespace:PackWatch.Application.Navigation;assembly=PackWatch.Application"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PackWatch"
        MinHeight="720"
        MinWidth="1120"
        Height="760"
        Width="1180">
    <Grid Background="{StaticResource PackWatchBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="268" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#F7FBFC"
                BorderBrush="#E1EAEE"
                BorderThickness="0,0,1,0"
                Padding="20">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <Border Background="{StaticResource PackWatchAccentDarkBrush}"
                            CornerRadius="14"
                            Padding="16"
                            Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="PackWatch"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="Local validation console"
                                       Foreground="#CFE7EF" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="WORKSPACE"
                               Foreground="{StaticResource PackWatchMutedTextBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="2,0,0,10" />

                    <Button Content="Home"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static application:ApplicationPage.Home}"
                            Style="{StaticResource NavigationButtonStyle}" />
                    <Button Content="History"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static application:ApplicationPage.History}"
                            Style="{StaticResource NavigationButtonStyle}" />
                    <Button Content="Settings"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static application:ApplicationPage.Settings}"
                            Style="{StaticResource NavigationButtonStyle}" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Style="{StaticResource StatusPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="Status"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource PackWatchTextBrush}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPageViewModel}"
                        Margin="28" />
    </Grid>
</Window>
