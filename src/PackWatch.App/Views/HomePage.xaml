<UserControl x:Class="PackWatch.App.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Live Camera"
                       Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="Preview, detection status, and current packing session."
                       Style="{StaticResource PageSubtitleStyle}" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#101820"
                        CornerRadius="8"
                        MinHeight="460">
                    <Grid>
                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="#243642"
                                CornerRadius="6"
                                Padding="10,6"
                                Margin="14">
                            <TextBlock Text="{Binding Fps, StringFormat=FPS {0}}"
                                       Foreground="#DDE7EC"
                                       Typography.NumeralAlignment="Tabular" />
                        </Border>

                        <TextBlock Text="{Binding PreviewMessage}"
                                   Foreground="#DDE7EC"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="42"
                                   MaxWidth="420" />
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="{StaticResource PackWatchSoftSurfaceBrush}"
                        CornerRadius="8"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Session"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <TextBlock Text="Camera Status" Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Text="{Binding CameraStatus}" Style="{StaticResource MetricValueStyle}" />

                        <TextBlock Text="Recording Status" Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Text="{Binding RecordingStatus}" Style="{StaticResource MetricValueStyle}" />

                        <TextBlock Text="Current Order" Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Text="{Binding CurrentOrder}" Style="{StaticResource MetricValueStyle}" />

                        <TextBlock Text="Recording Time" Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Text="{Binding RecordingTime}" Style="{StaticResource MetricValueStyle}" />

                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Last Barcode" Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding LastBarcode}" FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Resolution" Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding Resolution}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Start"
                    Command="{Binding StartCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,12,0" />
            <Button Content="Stop"
                    Command="{Binding StopCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" />
        </StackPanel>
    </Grid>
</UserControl>
