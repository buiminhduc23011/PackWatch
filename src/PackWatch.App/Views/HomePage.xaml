<UserControl x:Class="PackWatch.App.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Live Camera"
                   Style="{StaticResource PageTitleStyle}" />

        <Border Grid.Row="1"
                Background="{StaticResource PackWatchSurfaceBrush}"
                BorderBrush="{StaticResource PackWatchBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#101820"
                        CornerRadius="6"
                        MinHeight="420">
                    <TextBlock Text="{Binding PreviewMessage}"
                               Foreground="#DDE7EC"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="36" />
                </Border>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Camera Status" Foreground="{StaticResource PackWatchMutedTextBrush}" />
                    <TextBlock Text="{Binding CameraStatus}" FontWeight="SemiBold" Margin="0,4,0,18" />

                    <TextBlock Text="Recording Status" Foreground="{StaticResource PackWatchMutedTextBrush}" />
                    <TextBlock Text="{Binding RecordingStatus}" FontWeight="SemiBold" Margin="0,4,0,18" />

                    <TextBlock Text="Current Order" Foreground="{StaticResource PackWatchMutedTextBrush}" />
                    <TextBlock Text="{Binding CurrentOrder}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,18" />

                    <TextBlock Text="Recording Time" Foreground="{StaticResource PackWatchMutedTextBrush}" />
                    <TextBlock Text="{Binding RecordingTime}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,18" />

                    <TextBlock Text="Last Barcode" Foreground="{StaticResource PackWatchMutedTextBrush}" />
                    <TextBlock Text="{Binding LastBarcode}" FontWeight="SemiBold" Margin="0,4,0,18" />

                    <TextBlock Text="FPS" Foreground="{StaticResource PackWatchMutedTextBrush}" />
                    <TextBlock Text="{Binding Fps}" FontWeight="SemiBold" Margin="0,4,0,18" />

                    <TextBlock Text="Resolution" Foreground="{StaticResource PackWatchMutedTextBrush}" />
                    <TextBlock Text="{Binding Resolution}" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Start"
                    Command="{Binding StartCommand}"
                    MinWidth="120"
                    Padding="18,10"
                    Margin="0,0,12,0" />
            <Button Content="Stop"
                    Command="{Binding StopCommand}"
                    MinWidth="120"
                    Padding="18,10" />
        </StackPanel>
    </Grid>
</UserControl>
