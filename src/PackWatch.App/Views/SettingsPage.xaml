<UserControl x:Class="PackWatch.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>



        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: CAMERA & RECORDING -->
                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Camera &amp; Recording"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0" />
                            <Border Grid.Column="1"
                                    Style="{StaticResource CardBadgeStyle}"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="{Binding CameraModeBadge}"
                                           Style="{StaticResource CardBadgeTextStyle}" />
                            </Border>
                        </Grid>

                        <TextBlock Text="Configure your camera source and recording parameters."
                                   Style="{StaticResource FieldHelpStyle}"
                                   Margin="0,0,0,16" />

                        <!-- Source mode -->
                        <Border Style="{StaticResource InsetCardStyle}"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Source mode"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding CameraModes}"
                                          SelectedItem="{Binding CameraMode}"
                                          Margin="0" />
                            </StackPanel>
                        </Border>

                        <!-- Dynamic Source Settings -->
                        <Grid Margin="0,0,0,14">
                            <Border Style="{StaticResource InsetCardStyle}"
                                    Visibility="{Binding IsWebcamCamera, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Webcam source"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding WebcamProfiles}"
                                              SelectedItem="{Binding SelectedWebcamProfile}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InsetCardStyle}"
                                    Visibility="{Binding IsRtspCamera, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="RTSP source"
                                               Style="{StaticResource FieldLabelStyle}" />

                                    <TextBlock Text="RTSP URL"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding RtspUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Height="34" Padding="8,4"
                                             Margin="0,0,0,14" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Username"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                                     Height="34" Padding="8,4" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Password"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                                     Height="34" Padding="8,4" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Save Folder -->
                        <Border Style="{StaticResource InsetCardStyle}"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Save folder"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{Binding SaveFolder, UpdateSourceTrigger=PropertyChanged}"
                                             Height="34" Padding="8,4" />

                                    <Button Grid.Column="2"
                                            Content="Open"
                                            Command="{Binding OpenSaveFolderCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Height="34" MinHeight="0"
                                            MinWidth="80" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- FPS & Resolution -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="FPS"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding FramesPerSecondOptions}"
                                          SelectedItem="{Binding FramesPerSecond}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Resolution"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding ResolutionOptions}"
                                          SelectedItem="{Binding Resolution}" />
                            </StackPanel>
                        </Grid>

                        <!-- Bitrate & Video Format -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bitrate Kbps"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding BitrateKbps, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Video format"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding VideoFormatOptions}"
                                          SelectedItem="{Binding VideoFormat}" />
                            </StackPanel>
                        </Grid>

                        <!-- Connection Controls -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="Test Source"
                                    Command="{Binding TestConnectionCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,10,0" />
                            <Button Content="Preview Source"
                                    Command="{Binding PreviewCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- RIGHT COLUMN: BARCODE & OPERATIONS -->
                <Border Grid.Column="2"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <!-- Section Header: Barcode -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Barcode &amp; System"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0" />
                            <Border Grid.Column="1"
                                    Style="{StaticResource CardBadgeStyle}"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="{Binding BarcodeTypesSummary}"
                                           Style="{StaticResource CardBadgeTextStyle}" />
                            </Border>
                        </Grid>

                        <TextBlock Text="Set up barcode ROI limits, active symbologies, and logging policy."
                                   Style="{StaticResource FieldHelpStyle}"
                                   Margin="0,0,0,16" />

                        <!-- Region of Interest -->
                        <Border Style="{StaticResource InsetCardStyle}"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Scan region (ROI)"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding RoiSummary}"
                                           Style="{StaticResource CardSummaryStyle}"
                                           Margin="0,0,0,12" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="X" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding RoiX, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Y" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding RoiY, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="W" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding RoiWidth, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="6">
                                            <TextBlock Text="H" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding RoiHeight, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Stable Window -->
                        <Border Style="{StaticResource InsetCardStyle}"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Stable detection window"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="82" />
                                    </Grid.ColumnDefinitions>

                                    <Slider Grid.Column="0"
                                            Minimum="500"
                                            Maximum="1000"
                                            TickFrequency="50"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding StableBarcodeMilliseconds}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StableBarcodeMilliseconds, StringFormat={}{0:0} ms}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               FontWeight="SemiBold"
                                               Typography.NumeralAlignment="Tabular" />
                                </Grid>
                                <TextBlock Text="Keep the scanning window tight and detection stable for fast lock-ons."
                                           Style="{StaticResource FieldHelpStyle}" />
                            </StackPanel>
                        </Border>

                        <!-- Barcode Types -->
                        <Border Style="{StaticResource InsetCardStyle}"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Supported Symbologies"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Margin="0,0,0,8" />
                                <UniformGrid Columns="2">
                                    <CheckBox Content="QR Code" IsChecked="{Binding EnableQrCode}" />
                                    <CheckBox Content="Code128" IsChecked="{Binding EnableCode128}" />
                                    <CheckBox Content="Code39" IsChecked="{Binding EnableCode39}" />
                                    <CheckBox Content="EAN13" IsChecked="{Binding EnableEan13}" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- System Operations -->
                        <Border Style="{StaticResource InsetCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Auto-delete"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding RetentionOptions}"
                                              SelectedItem="{Binding RetentionPolicy}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Logging"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding LoggingLevelOptions}"
                                              SelectedItem="{Binding LoggingLevel}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Style="{StaticResource StatusPanelStyle}"
                Margin="0,18,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,16,0">
                    <TextBlock Text="Session status"
                               Style="{StaticResource FieldLabelStyle}"
                               Margin="0,0,0,2" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource PackWatchTextBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding RecordingSummary}"
                               Style="{StaticResource FieldHelpStyle}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Save Settings"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="18,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
