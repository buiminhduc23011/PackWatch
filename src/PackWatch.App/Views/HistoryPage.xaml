<UserControl x:Class="PackWatch.App.Views.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Search order" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="SearchTextBox" Text="{Binding SearchOrderCode, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Open Folder"
                        Command="{Binding OpenFolderCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Bottom"
                        MinWidth="128" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Border Style="{StaticResource InsetCardStyle}" Visibility="{Binding EmptyStateVisibility}">
                    <TextBlock Text="{Binding EmptyStateMessage}"
                               Foreground="{StaticResource PackWatchMutedTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="420" />
                </Border>

                <Grid Visibility="{Binding ResultsVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                        <ItemsControl ItemsSource="{Binding Records}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource InsetCardStyle}" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="1.6*" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Background="{StaticResource PackWatchAccentBrush}"
                                                    CornerRadius="10"
                                                    Width="48"
                                                    Height="48"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding BadgeText}"
                                                           Foreground="White"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Typography.NumeralAlignment="Tabular" />
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding OrderCode}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PackWatchTextBrush}" />
                                                <TextBlock Text="{Binding CameraName}" Style="{StaticResource FieldHelpStyle}" Margin="0,4,0,0" />
                                            </StackPanel>

                                            <Grid Grid.Column="2" Margin="0,0,16,0" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Started" Style="{StaticResource FieldLabelStyle}" />
                                                    <TextBlock Text="{Binding StartedAtText}" Style="{StaticResource CardSummaryStyle}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Ended" Style="{StaticResource FieldLabelStyle}" />
                                                    <TextBlock Text="{Binding EndedAtText}" Style="{StaticResource CardSummaryStyle}" />
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Grid.Column="3" Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Text="Duration" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{Binding DurationText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PackWatchTextBrush}" Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="4" Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Text="Artifact" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{Binding ArtifactName}" Style="{StaticResource CardSummaryStyle}" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding ArtifactPath}" Style="{StaticResource FieldHelpStyle}" Margin="0,4,0,0" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.OpenArtifactCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        MinWidth="40"
                                                        Width="40"
                                                        Height="40"
                                                        Padding="0"
                                                        ToolTip="Play video"
                                                        Margin="0,0,8,0">
                                                    <iconPacks:PackIconFontAwesome Kind="PlaySolid" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Button>
                                                <Button Command="{Binding DataContext.RevealArtifactCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        MinWidth="40"
                                                        Width="40"
                                                        Height="40"
                                                        Padding="0"
                                                        ToolTip="Show in Explorer"
                                                        Margin="0,0,8,0">
                                                    <iconPacks:PackIconFontAwesome Kind="FolderOpenSolid" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Button>
                                                <Button Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DangerButtonStyle}"
                                                        MinWidth="40"
                                                        Width="40"
                                                        Height="40"
                                                        Padding="0"
                                                        ToolTip="Delete record">
                                                    <iconPacks:PackIconFontAwesome Kind="TrashSolid" Width="14" Height="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Pagination Controls -->
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding PreviousPageCommand}"
                                IsEnabled="{Binding HasPreviousPage}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="110">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconFontAwesome Kind="ChevronLeftSolid" Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Previous" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Dynamic Page Number Buttons (e.g. 1 2 3 ... 8 9 10) -->
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding PageItems}" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <!-- Ellipsis -->
                                        <TextBlock x:Name="EllipsisText"
                                                   Text="..." 
                                                   Foreground="{StaticResource PackWatchMutedTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0"
                                                   FontWeight="SemiBold" />
                                        
                                        <!-- Page Button -->
                                        <Button x:Name="PageBtn"
                                                Content="{Binding Text}"
                                                Command="{Binding DataContext.JumpToSpecificPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding PageNumber}"
                                                MinWidth="36"
                                                Width="36"
                                                Height="36"
                                                Padding="0"
                                                Margin="4,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource PackWatchAccentBrush}" />
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource PackWatchAccentBrush}" />
                                                            <Setter Property="IsEnabled" Value="False" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                                            <Setter TargetName="EllipsisText" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="PageBtn" Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEllipsis}" Value="False">
                                            <Setter TargetName="EllipsisText" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="PageBtn" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Quick Jump Box -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="Go to" Foreground="{StaticResource PackWatchMutedTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Width="60" Height="40" Padding="0" Text="{Binding JumpPageInput, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" VerticalContentAlignment="Center">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding JumpToPageCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="page" Foreground="{StaticResource PackWatchMutedTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="3"
                                Command="{Binding NextPageCommand}"
                                IsEnabled="{Binding HasNextPage}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="110">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Next" VerticalAlignment="Center" />
                                <iconPacks:PackIconFontAwesome Kind="ChevronRightSolid" Width="10" Height="10" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
