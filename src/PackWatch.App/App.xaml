<Application
    x:Class="PackWatch.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:PackWatch.App.ViewModels"
    xmlns:views="clr-namespace:PackWatch.App.Views">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Color x:Key="PackWatchBackgroundColor">#F1F5F9</Color>
        <Color x:Key="PackWatchSurfaceColor">#FFFFFF</Color>
        <Color x:Key="PackWatchSoftSurfaceColor">#F8FAFC</Color>
        <Color x:Key="PackWatchAccentColor">#007BFF</Color>
        <Color x:Key="PackWatchAccentDarkColor">#0056B3</Color>
        <Color x:Key="PackWatchAccentSoftColor">#E6F0FF</Color>
        <Color x:Key="PackWatchSuccessColor">#10B981</Color>
        <Color x:Key="PackWatchWarningColor">#F59E0B</Color>
        <Color x:Key="PackWatchDangerColor">#EF4444</Color>
        <Color x:Key="PackWatchTextColor">#0F172A</Color>
        <Color x:Key="PackWatchMutedTextColor">#64748B</Color>
        <Color x:Key="PackWatchBorderColor">#E2E8F0</Color>

        <SolidColorBrush x:Key="PackWatchBackgroundBrush" Color="{StaticResource PackWatchBackgroundColor}" />
        <SolidColorBrush x:Key="PackWatchSurfaceBrush" Color="{StaticResource PackWatchSurfaceColor}" />
        <SolidColorBrush x:Key="PackWatchSoftSurfaceBrush" Color="{StaticResource PackWatchSoftSurfaceColor}" />
        <SolidColorBrush x:Key="PackWatchAccentBrush" Color="{StaticResource PackWatchAccentColor}" />
        <SolidColorBrush x:Key="PackWatchAccentDarkBrush" Color="{StaticResource PackWatchAccentDarkColor}" />
        <SolidColorBrush x:Key="PackWatchAccentSoftBrush" Color="{StaticResource PackWatchAccentSoftColor}" />
        <SolidColorBrush x:Key="PackWatchSuccessBrush" Color="{StaticResource PackWatchSuccessColor}" />
        <SolidColorBrush x:Key="PackWatchWarningBrush" Color="{StaticResource PackWatchWarningColor}" />
        <SolidColorBrush x:Key="PackWatchDangerBrush" Color="{StaticResource PackWatchDangerColor}" />
        <SolidColorBrush x:Key="PackWatchTextBrush" Color="{StaticResource PackWatchTextColor}" />
        <SolidColorBrush x:Key="PackWatchMutedTextBrush" Color="{StaticResource PackWatchMutedTextColor}" />
        <SolidColorBrush x:Key="PackWatchBorderBrush" Color="{StaticResource PackWatchBorderColor}" />

        <DropShadowEffect
            x:Key="CardShadow"
            BlurRadius="20"
            Direction="270"
            Opacity="0.04"
            ShadowDepth="4"
            Color="#0F172A" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="Background" Value="{StaticResource PackWatchBackgroundBrush}" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PackWatchSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PackWatchBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect" Value="{StaticResource CardShadow}" />
        </Style>

        <Style x:Key="InsetCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PackWatchSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PackWatchBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="StatusPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PackWatchSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="#D8E5E9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PackWatchMutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PackWatchMutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="FieldHelpStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PackWatchMutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style x:Key="CardSummaryStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        </Style>

        <Style x:Key="CardBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PackWatchAccentSoftBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CardBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PackWatchAccentDarkBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="Margin" Value="0,3,0,16" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="11,8" />
            <Setter Property="Background" Value="#FBFDFE" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PackWatchBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource PackWatchAccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border
                            x:Name="InputBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource PackWatchAccentBrush}" />
                                <Setter TargetName="InputBorder" Property="Background" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Background" Value="#EEF2F4" />
                                <Setter Property="Foreground" Value="#94A1AA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox ToggleButton Template -->
        <ControlTemplate x:Key="ComboBoxToggleButtonTemplate" TargetType="ToggleButton">
            <Border x:Name="TemplateRoot"
                    Background="White"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Path x:Name="Arrow"
                          Grid.Column="1"
                          Data="M 0 0 L 4.5 4.5 L 9 0"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,14,0"
                          Stroke="{StaticResource PackWatchMutedTextBrush}"
                          StrokeThickness="2" />
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="TemplateRoot" Property="Background" Value="#F1F5F9" />
                    <Setter TargetName="TemplateRoot" Property="BorderBrush" Value="#CBD5E1" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="TemplateRoot" Property="BorderBrush" Value="{StaticResource PackWatchAccentBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PackWatchBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid" SnapsToDevicePixels="true">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="0" SharedSizeGroup="ComboBoxButton" />
                            </Grid.ColumnDefinitions>
                            
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.ColumnSpan="2"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          ClickMode="Press"
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Template="{StaticResource ComboBoxToggleButtonTemplate}" />
                            
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="false"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            
                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="{TemplateBinding Padding}"
                                     Focusable="true"
                                     Background="Transparent"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}" />
                            
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="true"
                                   Focusable="false"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="true"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="White"
                                            BorderBrush="{StaticResource PackWatchBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,4,0,4">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Color="#0F172A" Opacity="0.08" Direction="270" />
                                        </Border.Effect>
                                        <ScrollViewer Margin="4" SnapsToDevicePixels="true">
                                            <StackPanel IsItemsHost="true" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="Height" Value="95" />
                            </Trigger>
                            <Trigger Property="IsGrouping" Value="true">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="false" />
                            </Trigger>
                            <Trigger Property="IsEditable" Value="true">
                                <Setter Property="IsTabStop" Value="false" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Margin="2,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource PackWatchAccentSoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PackWatchAccentDarkBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource PackWatchAccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource PackWatchSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PackWatchBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#F1F5F9" />
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource PackWatchAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PackWatchAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="{StaticResource PackWatchAccentDarkBrush}" />
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="{StaticResource PackWatchAccentDarkBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="SecondaryButtonStyle"
            BasedOn="{StaticResource BaseButtonStyle}"
            TargetType="Button" />

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource PackWatchDangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PackWatchDangerBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#DC2626" />
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#DC2626" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavigationButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="10,10" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavRoot"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <Border x:Name="Indicator"
                                        Grid.Column="0"
                                        Width="4"
                                        Height="18"
                                        CornerRadius="2"
                                        Background="{TemplateBinding BorderBrush}"
                                        Margin="4,0,8,0" />

                                <TextBlock x:Name="IconBlock"
                                           Grid.Column="1"
                                           Text="{TemplateBinding Tag}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Margin="4,0,12,0" />
                                
                                <ContentPresenter x:Name="TextContent"
                                                  Grid.Column="2"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  Margin="0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavRoot" Property="Background" Value="{StaticResource PackWatchAccentSoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PackWatchAccentDarkBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavRoot" Property="Background" Value="#D0E1FD" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=CollapseToggleButton}" Value="True">
                                <Setter TargetName="TextContent" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="IconBlock" Property="Margin" Value="4,0,0,0" />
                                <Setter Property="ToolTip" Value="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type viewModels:HomePageViewModel}">
            <views:HomePage />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:HistoryPageViewModel}">
            <views:HistoryPage />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:SettingsPageViewModel}">
            <views:SettingsPage />
        </DataTemplate>
    </Application.Resources>
</Application>
