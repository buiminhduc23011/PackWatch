<Application x:Class="PackWatch.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PackWatch.App.Views"
             xmlns:viewModels="clr-namespace:PackWatch.App.ViewModels">
    <Application.Resources>
        <SolidColorBrush x:Key="PackWatchBackgroundBrush" Color="#F4F7F9" />
        <SolidColorBrush x:Key="PackWatchSurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PackWatchAccentBrush" Color="#256D85" />
        <SolidColorBrush x:Key="PackWatchAccentDarkBrush" Color="#1B4F63" />
        <SolidColorBrush x:Key="PackWatchTextBrush" Color="#14212A" />
        <SolidColorBrush x:Key="PackWatchMutedTextBrush" Color="#62727D" />
        <SolidColorBrush x:Key="PackWatchBorderBrush" Color="#D8E1E6" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="Background" Value="{StaticResource PackWatchBackgroundBrush}" />
        </Style>

        <Style x:Key="NavigationButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E7F1F4" />
                                <Setter Property="BorderBrush" Value="#C8DDE4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D7E9EF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PackWatchTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <DataTemplate DataType="{x:Type viewModels:HomePageViewModel}">
            <views:HomePage />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:HistoryPageViewModel}">
            <views:HistoryPage />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:SettingsPageViewModel}">
            <views:SettingsPage />
        </DataTemplate>
    </Application.Resources>
</Application>
